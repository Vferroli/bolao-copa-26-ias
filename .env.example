# Supabase — Bolão Público (votação das IAs)
# Copie para `.env` e preencha. `.env` é gitignored (NÃO commitar).

# --- MCP (Claude usa p/ consultar o projeto e aplicar migrations) ---
# Personal Access Token: Supabase > Account > Access Tokens. SEGREDO.
SUPABASE_ACCESS_TOKEN=
# Ref do projeto (Project Settings > General > Reference ID). Ex.: abcd1234efgh5678
SUPABASE_PROJECT_REF=

# --- Frontend (público, embutido no JS — NÃO é segredo) ---
# Project Settings > Data API > Project URL. Ex.: https://<ref>.supabase.co
SUPABASE_URL=
# Project Settings > API Keys > anon / publishable key.
SUPABASE_ANON_KEY=
